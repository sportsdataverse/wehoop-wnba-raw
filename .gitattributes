# Normalize line endings to LF in the repo; let git convert on checkout per
# platform if core.autocrlf is set. Prevents phantom CRLF<->LF diffs on
# Windows checkouts when the working tree is regenerated by automation.
* text=auto eol=lf

# Treat these as binary (no EOL conversion, no diff text)
*.rds       binary
*.RData     binary
*.parquet   binary
*.tar.xz    binary
*.tar.gz    binary
*.zip       binary
*.gz        binary
*.feather   binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.pdf       binary
*.xlsx      binary
*.xls       binary
*.model     binary

# Shell scripts must be LF (Windows CRLF breaks them in bash/sh)
*.sh        text eol=lf
